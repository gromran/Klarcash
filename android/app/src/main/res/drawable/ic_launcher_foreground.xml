                android:pathData="M82,75L118,75"
                android:strokeColor="#085041"
                android:strokeWidth="2.5" />
        </group>
        <path
            android:pathData="M65,90h60a8,8 0 0 1 8,8v36a8,8 0 0 1 -8,8h-60a8,8 0 0 1 -8,-8v-36a8,8 0 0 1 8,-8z"
